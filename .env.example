# 这里是微信 AI 管家的配置文件
# 部署项目前，请将此文件重命名为 .env，并填入您的真实信息！

# ================= 大模型配置 =================
# 【必填】您的 MiniMax API Key
MINIMAX_API_KEY=sk-your_api_key_here

# 【选填】MiniMax 的接口地址 (通常不需要改)
MINIMAX_API_URL=https://api.minimax.chat/v1/chat/completions

# 【选填】大模型型号
MODEL_NAME=abab6.5s-chat

# ================= 微信群配置 =================
# 【必填】需要 AI 监听的群聊白名单。多个群请用英文逗号(,)分隔！
# 注意：必须与微信中群聊名称完全一致
WHITELIST_ROOMS=APP开发分类梳理,另一个测试群

# 【必填】AI 提取待办后的推送目标群。请务必在微信中将此群设为“保存到通讯录”！
TARGET_ROOM_NAME=水上的微信消息管家

# ================= 服务配置 =================
# 物理交接脚本轮询的接口端口 (默认 3000)
EXPRESS_PORT=3000